# RetailPro ERP environment configuration
# 1. Copy this file to .env
# 2. Fill in your live database credentials
# 3. NEVER commit .env to version control

DB_HOST=localhost
DB_NAME=retailpro
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Session idle timeout in seconds (default: 2 hours)
SESSION_TIMEOUT=7200
